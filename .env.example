# ───────────────────────────────────────────────
# DesignMirror AI — Environment Variables
# Copy this file to .env and fill in real values
# ───────────────────────────────────────────────

# --- App ---
APP_NAME=DesignMirror AI
APP_ENV=development
DEBUG=true

# --- MongoDB ---
MONGODB_URL=mongodb://designmirror_user:changeme_db_password@localhost:27017
MONGODB_DB_NAME=designmirror

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES-256 Encryption (for sensitive data at rest) ---
AES_ENCRYPTION_KEY=CHANGE_ME_TO_A_32_BYTE_HEX_STRING

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MODELS=design-mirror-models
MINIO_BUCKET_SCANS=design-mirror-scans

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
